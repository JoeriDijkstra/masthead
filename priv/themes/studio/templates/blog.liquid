<section class="hero">
  <p class="eyebrow">Writing</p>
  <h1>{{ page.title | escape }}</h1>
</section>

{% if body_html != "" %}
  <div class="prose blog-intro">{{ body_html }}</div>
{% endif %}

{% if tags != empty %}
  <nav class="tag-filter" aria-label="Filter posts by tag">
    <a href="{{ page.url }}" class="tag-filter-pill{% unless current_tag %} tag-filter-pill-active{% endunless %}">All</a>
    {% for tag in tags %}
      <a href="?tag={{ tag.slug }}" class="tag-filter-pill{% if tag.active %} tag-filter-pill-active{% endif %}">{{ tag.name | escape }}</a>
    {% endfor %}
  </nav>
{% endif %}

{% if posts == empty %}
  <section class="empty-state">
    <p>No posts yet.</p>
  </section>
{% else %}
  <section class="archive">
    <h2 class="section-title">{% if current_tag %}Posts tagged “{{ current_tag.name | escape }}”{% else %}All posts{% endif %}</h2>
    <ul class="post-grid">
      {% for p in posts %}
        <li>
          <a href="{{ p.url }}" class="post-card">
            <h3>{{ p.title | escape }}</h3>
            {% if p.excerpt != "" %}<p class="excerpt">{{ p.excerpt | escape }}</p>{% endif %}
            {% if p.published_at %}
              <time datetime="{{ p.published_at | iso8601 }}">{{ p.published_at | strftime: "%b %-d, %Y" }}</time>
            {% endif %}
          </a>
        </li>
      {% endfor %}
    </ul>
  </section>
{% endif %}
