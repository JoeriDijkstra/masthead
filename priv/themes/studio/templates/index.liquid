<section class="hero">
  <p class="eyebrow">{{ site.name | escape }}</p>
  <h1>{{ site.title | default: site.name | escape }}</h1>
  {% if site.description != "" %}<p class="lede">{{ site.description | escape }}</p>{% endif %}
  {% if theme.tokens.show_search %}
    <form action="/search" method="get" class="search-form" role="search">
      <input type="search" name="q" value="{{ search_query | escape }}" placeholder="Search posts&hellip;" aria-label="Search posts" />
    </form>
  {% endif %}
</section>

{% if search_query %}
  <p class="search-summary">{{ search_count }} result{% unless search_count == 1 %}s{% endunless %} for &ldquo;{{ search_query | escape }}&rdquo;</p>
{% endif %}

{% if posts == empty %}
  <section class="empty-state">
    <p>{% if search_query %}No posts match your search.{% else %}No posts yet. Check back soon.{% endif %}</p>
  </section>
{% else %}
  {% assign featured = posts | first %}
  <section class="featured">
    <a href="{{ featured.url }}" class="featured-card">
      <span class="card-eyebrow">Latest</span>
      <h2>{{ featured.title | escape }}</h2>
      {% if featured.excerpt != "" %}<p class="featured-excerpt">{{ featured.excerpt | escape }}</p>{% endif %}
      <div class="meta">
        {% if featured.published_at %}
          <time datetime="{{ featured.published_at | iso8601 }}">{{ featured.published_at | strftime: "%b %-d, %Y" }}</time>
        {% endif %}
        <span class="read-more">Read &rarr;</span>
      </div>
    </a>
  </section>

  {% assign rest = posts | slice: 1, 100 %}
  {% if rest != empty %}
    <section class="archive">
      <h2 class="section-title">More writing</h2>
      <ul class="post-grid">
        {% for p in rest %}
          <li>
            <a href="{{ p.url }}" class="post-card">
              <h3>{{ p.title | escape }}</h3>
              {% if p.excerpt != "" %}<p class="excerpt">{{ p.excerpt | escape }}</p>{% endif %}
              {% if p.published_at %}
                <time datetime="{{ p.published_at | iso8601 }}">{{ p.published_at | strftime: "%b %-d, %Y" }}</time>
              {% endif %}
            </a>
          </li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}
{% endif %}
