<article class="post">
  <header class="post-header">
    <p class="eyebrow">
      <a href="/">{{ site.name | escape }}</a>
      <span class="dot">&middot;</span>
      {% if post.published_at %}
        <time datetime="{{ post.published_at | iso8601 }}">{{ post.published_at | strftime: "%B %-d, %Y" }}</time>
      {% endif %}
    </p>
    <h1>{{ post.title | escape }}</h1>
    {% if post.excerpt != "" %}<p class="lede">{{ post.excerpt | escape }}</p>{% endif %}
  </header>

  <div class="prose">
    {{ body_html }}
  </div>

  <footer class="post-footer">
    <a href="/" class="back-link">&larr; Back to {{ site.name | escape }}</a>
  </footer>
</article>
