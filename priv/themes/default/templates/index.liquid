<header class="site-header">
  <h1>{{ site.title | default: site.name | escape }}</h1>
  {% if site.description != "" %}<p>{{ site.description | escape }}</p>{% endif %}
  <form action="/search" method="get" class="search-form" role="search">
    <input type="search" name="q" value="{{ search_query | escape }}" placeholder="Search posts&hellip;" aria-label="Search posts" />
  </form>
</header>

{% if search_query %}
  <p class="search-summary">{{ search_count }} result{% unless search_count == 1 %}s{% endunless %} for &ldquo;{{ search_query | escape }}&rdquo;</p>
{% endif %}

{% if posts == empty %}
  <section class="empty"><p>{% if search_query %}No posts match your search.{% else %}No posts yet.{% endif %}</p></section>
{% else %}
  <ul class="post-list">
    {% for post in posts %}
      <li>
        <a href="{{ post.url }}">
          <h2>{{ post.title | escape }}</h2>
          {% if post.excerpt != "" %}<p class="excerpt">{{ post.excerpt | escape }}</p>{% endif %}
          {% if post.published_at %}
            <time datetime="{{ post.published_at | iso8601 }}">{{ post.published_at | strftime: "%B %-d, %Y" }}</time>
          {% endif %}
        </a>
        {% if post.tags != empty %}
          <ul class="tag-list">
            {% for tag in post.tags %}
              <li class="tag-pill">{{ tag.name | escape }}</li>
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
{% endif %}
