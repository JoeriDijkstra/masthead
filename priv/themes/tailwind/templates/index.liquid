<section class="border-b border-gray-200 bg-gradient-to-b from-gray-50 to-white">
  <div class="mx-auto max-w-3xl px-6 py-24 text-center sm:py-32">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">{{ site.title | default: site.name | escape }}</h1>
    {% if site.description != "" %}<p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">{{ site.description | escape }}</p>{% endif %}
    {% if theme.tokens.cta_label != "" %}
      <div class="mt-10">
        <a href="{{ theme.tokens.cta_url | default: '/' }}" class="inline-block rounded-md bg-[var(--accent)] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:opacity-90">{{ theme.tokens.cta_label | escape }}</a>
      </div>
    {% endif %}
    {% if theme.tokens.show_search %}
      <form action="/search" method="get" role="search" class="mx-auto mt-10 max-w-md">
        <input type="search" name="q" value="{{ search_query | escape }}" placeholder="Search posts&hellip;" aria-label="Search posts" style="width:100%" class="rounded-md border border-gray-300 px-4 py-2 text-gray-900 shadow-sm focus:border-[var(--accent)] focus:outline-none" />
      </form>
    {% endif %}
  </div>
</section>

{% if search_query %}
  <p class="mx-auto max-w-6xl px-6 pt-12 text-sm text-gray-500">{{ search_count }} result{% unless search_count == 1 %}s{% endunless %} for &ldquo;{{ search_query | escape }}&rdquo;</p>
{% endif %}

{% if posts == empty and search_query %}
  <section class="mx-auto max-w-6xl px-6 py-16 text-gray-600">No posts match your search.</section>
{% endif %}

{% unless posts == empty %}
  <section class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
    <h2 class="text-2xl font-bold tracking-tight text-gray-900">Latest updates</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {% for p in posts %}
        <a href="{{ p.url }}" class="group rounded-2xl border border-gray-200 p-6 transition hover:border-gray-300 hover:shadow-md">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-[var(--accent)]">{{ p.title | escape }}</h3>
          {% if p.excerpt != "" %}<p class="mt-2 text-gray-600">{{ p.excerpt | escape }}</p>{% endif %}
          {% if p.published_at %}<time datetime="{{ p.published_at | iso8601 }}" class="mt-4 block text-sm text-gray-400">{{ p.published_at | strftime: "%b %-d, %Y" }}</time>{% endif %}
        </a>
      {% endfor %}
    </div>
  </section>
{% endunless %}
