<article class="mx-auto max-w-3xl px-6 py-16">
  <header class="mb-10">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">{{ post.title | escape }}</h1>
    {% if post.published_at %}
      <p class="mt-3 text-gray-500">
        <time datetime="{{ post.published_at | iso8601 }}">{{ post.published_at | strftime: "%B %-d, %Y" }}</time>
      </p>
    {% endif %}
    {% if post.excerpt != "" %}<p class="mt-4 text-xl text-gray-600">{{ post.excerpt | escape }}</p>{% endif %}
  </header>

  <div class="prose prose-lg max-w-none">
    {{ body_html }}
  </div>

  <footer class="mt-12 border-t border-gray-200 pt-6">
    <a href="/" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Back to {{ site.name | escape }}</a>
  </footer>
</article>
