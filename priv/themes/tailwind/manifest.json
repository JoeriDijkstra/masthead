{
  "name": "Tailwind",
  "slug": "tailwind",
  "version": "1.5.0",
  "author": "Masthead",
  "description": "A customizable, website-first theme styled with Tailwind CSS: full navbar with an uploadable logo, brand colors for the header/footer/buttons, light or dark header/footer text, a hero, and a card grid. Loaded from the Tailwind CDN so you can use any utility class in your pages.",
  "tokens": [
    {
      "key": "show_search",
      "label": "Show post search",
      "type": "boolean",
      "default": false
    },
    {
      "key": "logo",
      "label": "Logo",
      "type": "file",
      "default": ""
    },
    {
      "key": "favicon",
      "label": "Favicon",
      "type": "file",
      "default": ""
    },
    {
      "key": "header_text",
      "label": "Header text (next to logo)",
      "type": "string",
      "default": "",
      "category": "Header"
    },
    {
      "key": "header_color",
      "label": "Header background",
      "type": "color",
      "default": "#ffffff",
      "category": "Header"
    },
    {
      "key": "header_style",
      "label": "Header text color",
      "type": "select",
      "options": ["dark", "light"],
      "default": "dark",
      "category": "Header"
    },
    {
      "key": "header_width",
      "label": "Header & footer width",
      "type": "select",
      "options": ["contained", "full"],
      "default": "contained",
      "category": "Header"
    },
    {
      "key": "accent",
      "label": "Accent color (buttons)",
      "type": "color",
      "default": "#4f46e5"
    },
    {
      "key": "cta_label",
      "label": "Nav button label",
      "type": "string",
      "default": ""
    },
    {
      "key": "cta_url",
      "label": "Nav button link",
      "type": "string",
      "default": ""
    },
    {
      "key": "footer_color",
      "label": "Footer background",
      "type": "color",
      "default": "#f9fafb",
      "category": "Footer"
    },
    {
      "key": "footer_style",
      "label": "Footer text color",
      "type": "select",
      "options": ["dark", "light"],
      "default": "dark",
      "category": "Footer"
    }
  ],
  "metadata": [
    {
      "key": "layout",
      "label": "Page layout",
      "type": "select",
      "options": ["contained", "wide"],
      "default": "contained",
      "description": "Use 'wide' for full-width pages like a landing page; 'contained' centers a readable column."
    },
    {
      "key": "show_navigation",
      "label": "Show site navigation",
      "type": "boolean",
      "default": true,
      "description": "Untick to hide the navbar and footer on this page only — useful for a standalone splash page."
    }
  ]
}
