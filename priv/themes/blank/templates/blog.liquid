<section class="default-index">
  <h1>{{ page.title | escape }}</h1>
  {% if body_html != "" %}<div>{{ body_html }}</div>{% endif %}

  {% if posts != empty %}
    <ul>
      {% for post in posts %}
        <li>
          <a href="{{ post.url }}">{{ post.title | escape }}</a>
          {% if post.published_at %}
            <time>{{ post.published_at | strftime: "%Y-%m-%d" }}</time>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>No posts yet.</p>
  {% endif %}
</section>
